<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
</head>
<body>
    <div class="content">
        <ul>
            <% for (i = 0; i < messages.length; i++) { %>
                <li>
                    <p><%= messages[i].user %></p>
                    <p><%= messages[i].text %></p>
                    <p><%= messages[i].added %></p>
                </li>
            <% } %>
        </ul>
        <a href="/new">
            <button type="button">Write new Message</button>
        </a>
    </div>
</body>
</html>